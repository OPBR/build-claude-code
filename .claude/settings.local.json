{
  "permissions": {
    "allow": ["Bash(pnpm typecheck:*)", "Bash(pnpm tsc:*)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm typecheck 2>/dev/null || true && pnpm format 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
