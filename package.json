    "s04": "tsx src/sessions/s04-subagent.ts",
    "s05": "tsx src/sessions/s05-skill-loading.ts",
    "s06": "tsx src/sessions/s06-context-compact.ts",
    "s07": "tsx src/sessions/s07-permission-system.ts",
    "s08": "tsx src/sessions/s08-hook-system.ts",
    "s09": "tsx src/sessions/s09-memory-system.ts",
    "s10": "tsx src/sessions/s10-system-prompt.ts",
    "s11": "tsx src/sessions/s11-error-recovery.ts",
    "s12": "tsx src/sessions/s12-task-system.ts",
    "s13": "tsx src/sessions/s13-background-tasks.ts",
    "s14": "tsx src/sessions/s14-cron-scheduler.ts",
    "s15": "tsx src/sessions/s15-agent-teams.ts",
    "s16": "tsx src/sessions/s16-team-protocols.ts",
    "s17": "tsx src/sessions/s17-autonomous-agents.ts",
    "s18": "tsx src/sessions/s18-worktree-isolation.ts",
    "s19": "tsx src/sessions/s19-mcp-plugin.ts",
