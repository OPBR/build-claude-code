  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.5.0",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "tsdown": "^0.11.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=20.0.0"
  }
