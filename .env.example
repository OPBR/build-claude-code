# =============================================================================
#  API 配置
#  当前项目使用 Anthropic SDK，支持以下提供商
# =============================================================================

# Anthropic API (官方)
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# MODEL_ID=claude-sonnet-4-20250514

# =============================================================================
#  阿里云百炼 Coding Plan (推荐国内使用)
#  https://bailian.console.aliyun.com
# =============================================================================

# 百炼 Coding Plan 使用 ANTHROPIC_AUTH_TOKEN 和特殊 endpoint
ANTHROPIC_AUTH_TOKEN=your-bailian-api-key
ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_MODEL=qwen3.6-plus

# =============================================================================
#  Anthropic 兼容提供商 (国内)
#
#  Provider    MODEL_ID          SWE-bench  Base URL
#  ----------  ----------------  ---------  -------------------------------
#  智谱 GLM    glm-5             77.8%      open.bigmodel.cn/api/anthropic
#  DeepSeek    deepseek-chat     73.0%      api.deepseek.com/anthropic
#  Kimi        kimi-k2.5         76.8%      api.moonshot.cn/anthropic
#  MiniMax     MiniMax-M2.5      80.2%      api.minimaxi.com/anthropic
# =============================================================================

# 智谱 GLM https://open.bigmodel.cn
# ANTHROPIC_API_KEY=your-zhipu-api-key
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# MODEL_ID=glm-5

# DeepSeek https://platform.deepseek.com
# ANTHROPIC_API_KEY=your-deepseek-api-key
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# MODEL_ID=deepseek-chat

# Kimi (Moonshot) https://platform.moonshot.cn
# ANTHROPIC_API_KEY=your-moonshot-api-key
# ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic
# MODEL_ID=kimi-k2.5

# MiniMax https://platform.minimax.io
# ANTHROPIC_API_KEY=your-minimax-api-key
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# MODEL_ID=MiniMax-M2.5

# =============================================================================
#  国际提供商
# =============================================================================

# OpenRouter https://openrouter.ai
# ANTHROPIC_API_KEY=your-openrouter-api-key
# ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
# MODEL_ID=anthropic/claude-sonnet-4